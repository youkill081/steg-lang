section .text
move_current_down:
    LOAD R1, [current_block_Y]
    ADDA R1, 1
    STOREA R1, current_block_Y
    RET

move_current_left:
    LOAD R1, [current_block_X]
    SUBA R1, 1
    STOREA R1, current_block_X
    RET

move_current_right:
    LOAD R1, [current_block_X]
    ADDA R1, 1
    STOREA R1, current_block_X
    RET