section .data
    lines_string "LINES-..."
    broken_lines 0

section .text

; Display Lines ;

display_broken_lines:
    LOAD R0, lines_string
    ADDA R0, 6 ; Move pointer to the number

    LOAD R1, 3 ; Number of digits
    LOAD R2,  [broken_lines] ; Number of broken lines
    CALL number_to_string

    LOAD R0, 104
    LOAD R1, 15
    WINDOW_DRAW_TEXT R0 R1 lines_string
    RET