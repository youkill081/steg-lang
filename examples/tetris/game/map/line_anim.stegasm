section .data
    anim_left_col  0
    anim_right_col 0

section .text

; start_line_clear_anim
; Call when set game_state to one
; Reset the clock and properly start the animation
start_line_clear_anim:
    LOAD R0, [anim_clock] ; R0 = clock descriptor
    CLOCK_RESET R0
    RET


; update_line_clear_anim
; Update the animation state
; call each frame when game_state = 1
update_line_clear_anim:
    ; Read the elapsed time
    LOAD R1, [anim_clock] ; R1 = clock descriptor
    CLOCK_GET_ELAPSED_MS R0, R1 ; R0 = ms écoulées

    CMPA R0, 500 ; Check Animation end after 500ms
    JA anim_apply_end
    JE anim_apply_end ; anim_apply_end if >= 500ms

    LOAD R1, R0
    DIVA R1, 75 ; R1 = palier

    ; left_col = 4 - palier
    LOAD R2, 4
    SUB R2, R1
    STOREA R2, anim_left_col

    ; right_col = 5 + palier
    LOAD R2, R1
    ADDA R2, 5
    STOREA R2, anim_right_col

    CALL draw_anim_crack_rows
    RET

anim_apply_end:
    CALL apply_line_clear

    LOAD R0, 0
    STOREA R0, game_state

    CALL move_next_to_current
    RET


; draw_anim_crack_rows
; For each pending line, hide drawed block [left_col..right_col]
draw_anim_crack_rows:
    LOAD R6, 0 ; R6 = slot (0..3)

crack_slot_loop:
    CMPA R6, 4
    JE crack_slot_done

    ; Read pending_rows[R6]
    LOAD R5, pending_rows
    ADD R5, R6
    LOAD R5, [R5] ; R5 = index of line or 255

    CMPA R5, 255
    JE crack_slot_next ; No line pending

    ; Loop on column [left_col .. right_col]
    LOAD R7, [anim_left_col]

crack_col_loop:
    LOAD R0, [anim_right_col]
    CMPR R7, R0
    JA crack_col_done ; R7 > right_col ; finished of this slot

    PUSH R5
    PUSH R6
    PUSH R7

    LOAD R1, R7 ; col
    LOAD R2, R5 ; row
    CALL compute_block_position_from_coords ; OUT : R0=X, R1=Y

    LOAD R2, 0
    LOAD R3, 0
    LOAD R4, 0
    WINDOW_SET_TEXTURE_COLOR_MASK R2, R3, R4
    WINDOW_DRAW_TEXTURE R0, R1, block_white_background
    WINDOW_RESET_TEXTURE_COLOR_MASK

    POP R7
    POP R6
    POP R5

    ADDA R7, 1
    JMP crack_col_loop

crack_col_done:
crack_slot_next:
    ADDA R6, 1
    JMP crack_slot_loop

crack_slot_done:
    RET
